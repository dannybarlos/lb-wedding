# ─── Feature flags (client-visible) ─────────────────────────────────────────
# IMPORTANT: NEXT_PUBLIC_* vars are baked in at build time.
# Changing them requires a full redeploy — they do NOT update at runtime.

# Set to "false" to close RSVP submissions.
NEXT_PUBLIC_RSVP_OPEN=true

# Set to "false" to hide the Registry page link.
NEXT_PUBLIC_REGISTRY_VISIBLE=true

# Set to "false" to hide the Travel page link.
NEXT_PUBLIC_TRAVEL_VISIBLE=true

# Set to "false" to hide the Love Story section.
NEXT_PUBLIC_LOVE_STORY_VISIBLE=true

# Set to "false" to disable the countdown timer section.
NEXT_PUBLIC_COUNTDOWN_ENABLED=true

# Set to "false" to disable confetti on the countdown.
NEXT_PUBLIC_COUNTDOWN_CONFETTI=true

# ─── Server-only flags (API routes only) ─────────────────────────────────────
# NOT exposed to the client bundle. Safe for secrets.

# RSVP backend driver. Options: mock | supabase | airtable | google_sheets
# Default: mock (logs to console, no external service required)
RSVP_BACKEND_DRIVER=mock

# ─── Supabase (only needed when RSVP_BACKEND_DRIVER=supabase) ────────────────
# Run: npm install @supabase/supabase-js
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── Airtable (only needed when RSVP_BACKEND_DRIVER=airtable) ────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=rsvps

# ─── Google Sheets (only needed when RSVP_BACKEND_DRIVER=google_sheets) ──────
GOOGLE_SHEETS_WEBHOOK_URL=
